TOOL_FOR_LOGO_WEB_PORT=19130
TOOL_FOR_LOGO_HOST_STATE_ROOT=C:\Codex\workspaces\ToolForLogo
TOOL_FOR_LOGO_HOST_REPORT_ROOT=C:\Codex\reports\ToolForLogo
TOOL_FOR_LOGO_HOST_ARCHIVE_ROOT=C:\Codex\archive\ToolForLogo
TOOL_FOR_LOGO_STATE_ROOT=/data/workspaces
TOOL_FOR_LOGO_REPORT_ROOT=/data/reports
TOOL_FOR_LOGO_ARCHIVE_ROOT=/data/archive
TOOL_FOR_LOGO_DEFAULT_BACKEND=comfyui
TOOL_FOR_LOGO_START_COMFYUI=1
TOOL_FOR_LOGO_COMFYUI_DIR=C:\apps\ComfyUI_windows_portable
TOOL_FOR_LOGO_COMFYUI_BASE_URL=http://host.docker.internal:8188
TOOL_FOR_LOGO_COMFYUI_CHECKPOINT=ponyDiffusionV6XL_v6StartWithThisOne.safetensors
TOOL_FOR_LOGO_COMFYUI_WIDTH=1024
TOOL_FOR_LOGO_COMFYUI_HEIGHT=1024
TOOL_FOR_LOGO_COMFYUI_STEPS=20
TOOL_FOR_LOGO_COMFYUI_CFG=6.5
TOOL_FOR_LOGO_COMFYUI_SAMPLER=dpmpp_2m_sde
TOOL_FOR_LOGO_COMFYUI_SCHEDULER=karras
TOOL_FOR_LOGO_COMFYUI_TIMEOUT_SECONDS=300
TOOL_FOR_LOGO_COMFYUI_POLL_SECONDS=2
TOOL_FOR_LOGO_COMFYUI_NEGATIVE_PROMPT=text, letters, wordmark, watermark, signature, mockup, poster, product photo, person, hand, scenery, 3d render, glossy, realistic, photorealistic, gradient mesh, cluttered background, anime, cartoon, pony, girl, face, eyes, body
TOOL_FOR_LOGO_IMAGE_MODEL=gpt-image-1.5
TOOL_FOR_LOGO_IMAGE_QUALITY=medium
TOOL_FOR_LOGO_IMAGE_SIZE=1024x1024
TOOL_FOR_LOGO_IMAGE_BACKGROUND=transparent
OPENAI_API_KEY=
TOOL_FOR_LOGO_SKIP_HELP_LINK=0
